<?xml version="1.0"?>
<robot name="open_box">
  <!-- fond -->
  <link name="base">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.3 0.2 0.02"/></geometry>
      <material name="cardboard"><color rgba="0.8 0.6 0.3 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.3 0.2 0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- paroi avant -->
  <link name="wall_front">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.3 0.02 0.15"/></geometry>
      <material name="cardboard"><color rgba="0.8 0.6 0.3 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.3 0.02 0.15"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="joint_front" type="fixed">
    <parent link="base"/>
    <child link="wall_front"/>
    <origin xyz="0 0.11 0.085" rpy="0 0 0"/>
  </joint>

  <!-- paroi arrière -->
  <link name="wall_back">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.3 0.02 0.15"/></geometry>
      <material name="cardboard"><color rgba="0.8 0.6 0.3 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.3 0.02 0.15"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="joint_back" type="fixed">
    <parent link="base"/>
    <child link="wall_back"/>
    <origin xyz="0 -0.11 0.085" rpy="0 0 0"/>
  </joint>

  <!-- paroi gauche -->
  <link name="wall_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.2 0.15"/></geometry>
      <material name="cardboard"><color rgba="0.8 0.6 0.3 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.2 0.15"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="joint_left" type="fixed">
    <parent link="base"/>
    <child link="wall_left"/>
    <origin xyz="0.16 0 0.085" rpy="0 0 0"/>
  </joint>

  <!-- paroi droite -->
  <link name="wall_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.2 0.15"/></geometry>
      <material name="cardboard"><color rgba="0.8 0.6 0.3 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.2 0.15"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="joint_right" type="fixed">
    <parent link="base"/>
    <child link="wall_right"/>
    <origin xyz="-0.16 0 0.085" rpy="0 0 0"/>
  </joint>
</robot>